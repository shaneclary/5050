# ==============================================================
# 50/50 For All — environment variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local (it is gitignored).
# ==============================================================

# -- Supabase (shared with mothership instance, fiftyfifty schema) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -- Resend (outbound: petition/endorsement verification emails) ----
RESEND_API_KEY=re_your_resend_api_key
RESEND_SENDER_EMAIL=noreply@5050forall.com

# -- ImprovMX (inbound: press@5050forall.com -> personal inbox) -----
# Only needed if the site programmatically manages aliases or reads
# delivery logs. For plain forwarding, the API key is not required.
IMPROVMX_API_KEY=

# -- Site -----------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3457
